generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Auth (NextAuth) ─────────────────────────────────────────────────
model User {
  id               String               @id @default(cuid())
  name             String?
  email            String               @unique
  emailVerified    DateTime?
  image            String?
  password         String?
  role             UserRole             @default(AGENT)
  departmentId     String?
  department       Department?          @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  teamId           String?
  team             Team?                @relation("TeamMembers", fields: [teamId], references: [id], onDelete: SetNull)
  accounts         Account[]
  sessions         Session[]
  opportunities    Opportunity[]
  assignedTickets  Ticket[]             @relation("TicketAssignee")
  createdTickets   Ticket[]             @relation("TicketCreator")
  ticketComments   TicketComment[]
  ticketActivities TicketActivity[]
  knowledgeArticles KnowledgeArticle[]
  leadOf           Team[]               @relation("TeamLead")
  orgMemberships   OrganizationMember[]
  enabledModules   OrganizationModule[] @relation("ModuleEnabledBy")
  callCenterProfile UserCallCenterProfile?
  ticketAttachments TicketAttachment[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([departmentId])
  @@index([teamId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Multi-tenant ─────────────────────────────────────────────────────
model Organization {
  id           String               @id @default(cuid())
  name         String
  slug         String               @unique
  plan         OrgPlan              @default(FREE)
  members      OrganizationMember[]
  modules      OrganizationModule[]
  tickets      Ticket[]
  contacts     Contact[]
  companies    Company[]
  opportunities Opportunity[]
  interactions OmnichannelInteraction[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@map("organizations")
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           MemberRole   @default(AGENT)
  joinedAt       DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("organization_members")
}

// ── Module System ─────────────────────────────────────────────────────
model OrganizationModule {
  id             String       @id @default(cuid())
  organizationId String
  module         ModuleType
  enabled        Boolean      @default(true)
  // Module-specific settings (e.g. CALL_CENTER: { signalrUrl, acsResourceId })
  config         Json         @default("{}")
  enabledAt      DateTime     @default(now())
  enabledById    String?
  enabledBy      User?        @relation("ModuleEnabledBy", fields: [enabledById], references: [id], onDelete: SetNull)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, module])
  @@index([organizationId])
  @@map("organization_modules")
}

// ── Call Center Bridge ────────────────────────────────────────────────
// Links a CRM user to their Azure Communication Services identity.
// Populated on first CC login; eliminates the need to query the CC Identity service.
model UserCallCenterProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  communicationUserId String?  @unique
  extension           String?
  maxConcurrentCalls  Int      @default(1)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("user_call_center_profiles")
}

// ── Omnichannel ───────────────────────────────────────────────────────
model OmnichannelInteraction {
  id             String               @id @default(cuid())
  channel        ChannelType
  direction      InteractionDirection
  externalId     String?
  from           String
  to             String
  body           String
  attachments    Json                 @default("[]")
  ticketId       String?
  ticket         Ticket?              @relation(fields: [ticketId], references: [id], onDelete: SetNull)
  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime             @default(now())

  @@index([organizationId, channel])
  @@index([ticketId])
  @@index([externalId])
  @@map("omnichannel_interactions")
}

// ── Internal structure ────────────────────────────────────────────────
model Department {
  id        String       @id @default(cuid())
  name      String
  code      String       @unique
  parentId  String?
  parent    Department?  @relation("DeptHierarchy", fields: [parentId], references: [id])
  children  Department[] @relation("DeptHierarchy")
  teams     Team[]
  tickets   Ticket[]
  users     User[]
  createdAt DateTime     @default(now())
}

model Team {
  id           String      @id @default(cuid())
  name         String
  description  String?
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  leadId       String?
  lead         User?       @relation("TeamLead", fields: [leadId], references: [id], onDelete: SetNull)
  members      User[]      @relation("TeamMembers")
  tickets      Ticket[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([departmentId])
}

model SLAPolicy {
  id                   String         @id @default(cuid())
  name                 String
  priority             TicketPriority
  firstResponseMinutes Int
  resolutionMinutes    Int
  tickets              Ticket[]
  createdAt            DateTime       @default(now())
}

// ── Tickets (ITSM) ────────────────────────────────────────────────────
model Ticket {
  id             String          @id @default(cuid())
  number         String          @unique
  title          String
  description    String
  status         TicketStatus    @default(NEW)
  priority       TicketPriority  @default(MEDIUM)
  type           TicketType      @default(INCIDENT)
  source         TicketSource    @default(PORTAL)
  category       String?
  tags           String[]        @default([])

  assigneeId     String?
  assignee       User?           @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  teamId         String?
  team           Team?           @relation(fields: [teamId], references: [id], onDelete: SetNull)
  departmentId   String?
  department     Department?     @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  contactId      String?
  contact        Contact?        @relation(fields: [contactId], references: [id], onDelete: SetNull)
  companyId      String?
  company        Company?        @relation(fields: [companyId], references: [id], onDelete: SetNull)

  slaPolicyId    String?
  slaPolicy      SLAPolicy?      @relation(fields: [slaPolicyId], references: [id], onDelete: SetNull)
  slaBreached    Boolean         @default(false)
  firstResponseAt DateTime?
  dueAt          DateTime?
  resolvedAt     DateTime?
  closedAt       DateTime?

  satisfactionScore Int?
  satisfactionNote  String?

  createdById    String
  createdBy      User            @relation("TicketCreator", fields: [createdById], references: [id])

  parentTicketId String?
  parentTicket   Ticket?         @relation("TicketChildren", fields: [parentTicketId], references: [id], onDelete: SetNull)
  childTickets   Ticket[]        @relation("TicketChildren")

  organizationId String?
  organization   Organization?   @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  comments       TicketComment[]
  activities     TicketActivity[]
  interactions   OmnichannelInteraction[]
  attachments    TicketAttachment[]

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([status])
  @@index([priority])
  @@index([type])
  @@index([assigneeId])
  @@index([teamId])
  @@index([departmentId])
  @@index([contactId])
  @@index([companyId])
  @@index([organizationId])
  @@index([parentTicketId])
  @@index([createdAt])
}

model TicketAttachment {
  id           String   @id @default(cuid())
  ticketId     String
  ticket       Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  fileName     String
  fileSize     Int
  mimeType     String
  blobUrl      String
  createdAt    DateTime @default(now())

  @@index([ticketId])
  @@map("ticket_attachments")
}

model TicketComment {
  id         String   @id @default(cuid())
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
  body       String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([ticketId])
}

model TicketActivity {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  meta      Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([ticketId])
}

// ── Knowledge Base ───────────────────────────────────────────────────
model KnowledgeCategory {
  id          String              @id @default(cuid())
  name        String
  slug        String              @unique
  description String?
  icon        String?
  parentId    String?
  parent      KnowledgeCategory?  @relation("KBCat", fields: [parentId], references: [id])
  children    KnowledgeCategory[] @relation("KBCat")
  articles    KnowledgeArticle[]
  createdAt   DateTime            @default(now())
}

model KnowledgeArticle {
  id         String             @id @default(cuid())
  title      String
  slug       String             @unique
  body       String
  status     KnowledgeStatus    @default(DRAFT)
  categoryId String?
  category   KnowledgeCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  authorId   String
  author     User               @relation(fields: [authorId], references: [id])
  views      Int                @default(0)
  helpful    Int                @default(0)
  notHelpful Int                @default(0)
  tags       String[]           @default([])
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([status])
  @@index([categoryId])
}

// ── CRM Core ──────────────────────────────────────────────────────────
model Company {
  id             String        @id @default(cuid())
  name           String
  industry       String?
  website        String?
  phone          String?
  email          String?
  address        String?
  city           String?
  country        String?
  size           CompanySize?
  revenue        Float?
  notes          String?
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  contacts       Contact[]
  opportunities  Opportunity[]
  tickets        Ticket[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([name])
  @@index([organizationId])
}

model Contact {
  id             String        @id @default(cuid())
  firstName      String
  lastName       String
  email          String?       @unique
  phone          String?
  title          String?
  status         ContactStatus @default(LEAD)
  notes          String?
  companyId      String?
  company        Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  opportunities  Opportunity[]
  tickets        Ticket[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([companyId])
  @@index([organizationId])
  @@index([status])
  @@index([email])
  @@index([phone])
}

model Opportunity {
  id             String           @id @default(cuid())
  title          String
  value          Float            @default(0)
  stage          OpportunityStage @default(LEAD)
  probability    Int              @default(0)
  closeDate      DateTime?
  notes          String?
  contactId      String?
  contact        Contact?         @relation(fields: [contactId], references: [id], onDelete: SetNull)
  companyId      String?
  company        Company?         @relation(fields: [companyId], references: [id], onDelete: SetNull)
  assignedToId   String?
  assignedTo     User?            @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  organizationId String?
  organization   Organization?    @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([stage])
  @@index([contactId])
  @@index([companyId])
  @@index([assignedToId])
  @@index([organizationId])
}

// ── Workflow Automation ───────────────────────────────────────────────
model WorkflowRule {
  id          String          @id @default(cuid())
  name        String
  description String?
  isActive    Boolean         @default(true)
  trigger     WorkflowTrigger
  conditions  Json            @default("[]")
  actions     Json            @default("[]")
  order       Int             @default(0)
  stopOnMatch Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([trigger, isActive])
  @@map("workflow_rules")
}

// ── Enums ─────────────────────────────────────────────────────────────
enum WorkflowTrigger {
  TICKET_CREATED
  TICKET_UPDATED
  TICKET_STATUS_CHANGED
  TICKET_PRIORITY_CHANGED
  TICKET_ASSIGNED
}

enum ModuleType {
  CRM          // Contacts, Companies, Opportunities, Pipeline
  SUPPORT      // Tickets, SLA, Knowledge Base, Reports
  CALL_CENTER  // Agent Desktop, Queues, IVR, ACS, Supervisor Dashboard
  HR           // Employees, Leave, Payroll
  FINANCE      // Invoices, Budget, Expenses
  GED          // Document Management
  INTEGRATIONS // API keys, Webhooks, External connectors
}

enum UserRole {
  ADMIN
  MANAGER
  AGENT
  CLIENT
}

enum TicketStatus {
  NEW
  OPEN
  PENDING
  ON_HOLD
  RESOLVED
  CLOSED
}

enum TicketPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum TicketType {
  INCIDENT
  SERVICE_REQUEST
  PROBLEM
  CHANGE
}

enum TicketSource {
  EMAIL
  PORTAL
  PHONE
  CHAT
  API
  SMS
  TEAMS
  WHATSAPP
}

enum OrgPlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum MemberRole {
  OWNER
  ADMIN
  MANAGER
  AGENT
  VIEWER
}

enum ChannelType {
  EMAIL
  SMS
  TEAMS
  WHATSAPP
  VOICE
  CHAT
  PORTAL
}

enum InteractionDirection {
  INBOUND
  OUTBOUND
}

enum KnowledgeStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ContactStatus {
  LEAD
  PROSPECT
  CLIENT
  INACTIVE
}

enum CompanySize {
  MICRO
  SMALL
  MEDIUM
  LARGE
}

enum OpportunityStage {
  LEAD
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}
